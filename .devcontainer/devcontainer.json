{
  "name": "Intel Pin Environment",
  "image": "mcr.microsoft.com/devcontainers/cpp:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {}
  },

  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined"
  ],
  "customizations": {
    "vscode": {
      // Installs the mandatory C++ extensions inside the container
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack"
      ]
    }
  },

  "postCreateCommand": "bash .devcontainer/setup_pin.sh",
  "remoteUser": "vscode"
}
